# -----------------------------------------------------------------
# github-3d-contribution Local Configuration Template
# Copy this file to '.env' and fill in your values
# -----------------------------------------------------------------

# GitHub Personal Access Token (PAT)
# Required for fetching private repositories, stars, and user stats.
# Create one at: https://github.com/settings/tokens
# Scopes needed: 'read:user', 'repo'
GH_TOKEN=your_personal_access_token_here

# The target GitHub Username to fetch statistics for
GITHUB_USERNAME=Abad-87

# Visual customization options
# Theme options: 'dark' or 'light'
THEME=dark

# Color palette options: 'green', 'blue', 'purple', 'orange'
PALETTE=green

# Enable/disable animations in the SVG outputs (true/false)
ANIMATED=true

# Enable/disable drop-shadows on isometric elements (true/false)
SHADOWS=true
